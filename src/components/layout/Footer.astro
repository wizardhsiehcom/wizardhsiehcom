---
const year = new Date().getFullYear()
---

<footer class="border-t border-elevated py-8">
  <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-slate-500 text-sm font-mono">
      © {year} Edison Hsieh. Built with
      <a href="https://astro.build" target="_blank" rel="noopener" class="text-accent-cyan hover:opacity-75 transition-opacity">
        Astro
      </a>
      &amp;
      <a href="https://tailwindcss.com" target="_blank" rel="noopener" class="text-accent-cyan hover:opacity-75 transition-opacity">
        Tailwind
      </a>.
    </p>
    <a
      href="#hero"
      class="text-slate-500 hover:text-accent-cyan transition-colors text-sm flex items-center gap-1.5"
    >
      Back to top
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
      </svg>
    </a>
  </div>
</footer>
