---
const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#skills', label: 'Skills' },
  { href: '#projects', label: 'Projects' },
  { href: '#experience', label: 'Experience' },
  { href: '#contact', label: 'Contact' },
]
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a
      href="#hero"
      class="font-mono text-accent-cyan font-semibold text-lg tracking-tight hover:opacity-75 transition-opacity"
    >
      wizardhsieh
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="text-slate-400 hover:text-accent-cyan transition-colors duration-200 text-sm font-medium"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="menu-btn"
      aria-label="Toggle navigation menu"
      class="md:hidden text-slate-400 hover:text-accent-cyan transition-colors p-1"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-elevated bg-surface/95 backdrop-blur-md">
    <ul class="flex flex-col py-2">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="block px-6 py-3 text-slate-300 hover:text-accent-cyan hover:bg-elevated transition-colors text-sm"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar')!
  const menuBtn = document.getElementById('menu-btn')!
  const mobileMenu = document.getElementById('mobile-menu')!
  const iconOpen = document.getElementById('icon-open')!
  const iconClose = document.getElementById('icon-close')!

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar.classList.add('bg-base/90', 'backdrop-blur-md', 'border-b', 'border-elevated')
    } else {
      navbar.classList.remove('bg-base/90', 'backdrop-blur-md', 'border-b', 'border-elevated')
    }
  })

  menuBtn.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden')
    mobileMenu.classList.toggle('hidden')
    iconOpen.classList.toggle('hidden', !isOpen)
    iconClose.classList.toggle('hidden', isOpen)
  })

  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden')
      iconOpen.classList.remove('hidden')
      iconClose.classList.add('hidden')
    })
  })
</script>
