---
import TerminalTyping from '../ui/TerminalTyping.astro'

const terminalLines = [
  { command: 'whoami', output: 'Edison Hsieh' },
  { command: 'cat role.txt', output: 'Full Stack Engineer' },
  { command: 'echo $LOCATION', output: 'Taiwan 🇹🇼' },
  { command: 'echo $INTERESTS', output: 'AI | Web | Open Source' },
]
---

<section id="hero" class="min-h-screen flex items-center bg-base relative overflow-hidden">
  <!-- Background gradient decoration -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-accent-purple/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-accent-cyan/5 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 py-24 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Text content -->
      <div>
        <p class="font-mono text-accent-cyan text-sm mb-3 tracking-widest uppercase">
          Hi there, I'm
        </p>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-slate-100 leading-tight mb-4">
          Edison<br />
          <span class="bg-gradient-to-r from-accent-cyan to-accent-purple bg-clip-text text-transparent">
            Hsieh
          </span>
        </h1>
        <div class="h-px w-16 bg-gradient-to-r from-accent-cyan to-accent-purple mb-6 rounded-full"></div>
        <p class="text-xl text-slate-300 font-medium mb-4">Full Stack Engineer</p>
        <p class="text-slate-400 leading-relaxed max-w-md mb-10">
          Building scalable web applications and AI-powered products.
          Passionate about clean code, great developer experience, and open source.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="#projects"
            class="px-6 py-3 bg-accent-cyan text-slate-900 font-semibold rounded-lg hover:bg-accent-cyan/90 active:scale-95 transition-all duration-150 text-sm"
          >
            View My Work
          </a>
          <a
            href="#contact"
            class="px-6 py-3 border border-accent-cyan/60 text-accent-cyan font-semibold rounded-lg hover:bg-accent-cyan/8 active:scale-95 transition-all duration-150 text-sm"
          >
            Contact Me
          </a>
        </div>
      </div>

      <!-- Right: Terminal (hidden on mobile) -->
      <div class="hidden lg:flex justify-center lg:justify-end">
        <TerminalTyping lines={terminalLines} startDelay={800} />
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <a
    href="#about"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 text-slate-500 hover:text-accent-cyan transition-colors duration-200 animate-bounce"
    aria-label="Scroll to About section"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </a>
</section>
