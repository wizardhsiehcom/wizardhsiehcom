---
import ProjectCard from '../ui/ProjectCard.astro'
import { projects } from '../../data/projects'
---

<section id="projects" class="py-24 bg-surface">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 reveal">
      <h2 class="section-heading">Projects</h2>
      <p class="section-subheading">Things I've built and shipped</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project, i) => (
        <div class="reveal" style={`transition-delay: ${(i % 3) * 100}ms`}>
          <ProjectCard {...project} />
        </div>
      ))}
    </div>

    <div class="text-center mt-12 reveal">
      <a
        href="https://github.com/wizardhsieh"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-accent-cyan hover:opacity-75 transition-opacity font-medium text-sm"
      >
        View all projects on GitHub
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </div>
</section>
