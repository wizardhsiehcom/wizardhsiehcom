---
import SkillBadge from '../ui/SkillBadge.astro'
import { skillCategories } from '../../data/skills'
---

<section id="skills" class="py-24 bg-base">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 reveal">
      <h2 class="section-heading">Skills & Tech Stack</h2>
      <p class="section-subheading">Technologies I use to build things</p>
    </div>

    <div class="space-y-10">
      {skillCategories.map((category, i) => (
        <div class="reveal" style={`transition-delay: ${i * 100}ms`}>
          <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-4 font-mono">
            {category.label}
          </h3>
          <div class="flex flex-wrap gap-3">
            {category.skills.map(skill => (
              <SkillBadge name={skill.name} icon={skill.icon} color={skill.color} />
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
