---
interface Props {
  title: string
  description: string
  image?: string
  tags: string[]
  githubUrl?: string
  demoUrl?: string
  featured?: boolean
}

const { title, description, image, tags, githubUrl, demoUrl, featured } = Astro.props
---

<article class="bg-surface border border-elevated rounded-xl overflow-hidden flex flex-col transition-all duration-300 hover:-translate-y-1.5 hover:border-accent-cyan/30 hover:shadow-[0_8px_30px_rgba(0,212,255,0.08)] group">
  <!-- Image / placeholder -->
  <div class="h-44 bg-elevated overflow-hidden relative">
    {image ? (
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <svg class="w-12 h-12 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
        </svg>
      </div>
    )}
    {featured && (
      <span class="absolute top-3 right-3 text-xs px-2.5 py-1 bg-accent-cyan/10 text-accent-cyan border border-accent-cyan/30 rounded-full font-medium backdrop-blur-sm">
        Featured
      </span>
    )}
  </div>

  <!-- Content -->
  <div class="p-5 flex flex-col flex-1">
    <h3 class="text-slate-100 font-semibold text-base mb-2 group-hover:text-accent-cyan transition-colors duration-200">
      {title}
    </h3>
    <p class="text-slate-400 text-sm leading-relaxed mb-4 flex-1">
      {description}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-1.5 mb-4">
      {tags.map(tag => (
        <span class="text-xs px-2 py-0.5 bg-elevated text-slate-300 rounded font-mono border border-elevated/80">
          {tag}
        </span>
      ))}
    </div>

    <!-- Links -->
    <div class="flex items-center gap-4 pt-1 border-t border-elevated">
      {githubUrl && (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-sm text-slate-400 hover:text-accent-cyan transition-colors duration-200"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
      )}
      {demoUrl && demoUrl !== '#' && (
        <a
          href={demoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-sm text-slate-400 hover:text-accent-cyan transition-colors duration-200"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          Live Demo
        </a>
      )}
    </div>
  </div>
</article>
