---
import { Icon } from 'astro-icon/components'

interface Props {
  name: string
  icon: string
  color?: string
}

const { name, icon, color = '#94a3b8' } = Astro.props
---

<div
  class="flex items-center gap-2.5 px-4 py-2.5 bg-surface border border-elevated rounded-lg hover:border-accent-cyan/40 hover:bg-elevated transition-all duration-200 cursor-default group"
>
  <Icon
    name={icon}
    class="w-5 h-5 shrink-0 transition-all duration-200"
    style={`color: ${color}`}
  />
  <span class="text-sm text-slate-300 group-hover:text-slate-100 transition-colors duration-200 font-medium">
    {name}
  </span>
</div>
