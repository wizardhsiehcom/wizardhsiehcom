---
interface Props {
  role: string
  company: string
  companyUrl?: string
  startDate: string
  endDate: string
  description: string[]
  tags: string[]
  type: 'work' | 'education'
  isLast?: boolean
}

const { role, company, companyUrl, startDate, endDate, description, tags, type, isLast } = Astro.props
---

<div class="relative pl-10 pb-10 last:pb-0">
  <!-- Vertical connector line -->
  {!isLast && (
    <div class="absolute left-[17px] top-6 bottom-0 w-px bg-elevated"></div>
  )}

  <!-- Timeline dot -->
  <div class={`absolute left-0 top-4 w-[34px] h-[34px] rounded-full border-2 flex items-center justify-center transition-colors ${type === 'work' ? 'border-accent-cyan bg-surface' : 'border-accent-purple bg-surface'}`}>
    {type === 'work' ? (
      <svg class="w-4 h-4 text-accent-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
    ) : (
      <svg class="w-4 h-4 text-accent-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
      </svg>
    )}
  </div>

  <!-- Card -->
  <div class="bg-surface border border-elevated rounded-xl p-5 hover:border-accent-cyan/25 transition-colors duration-200">
    <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
      <div>
        <h3 class="text-slate-100 font-semibold text-base">{role}</h3>
        {companyUrl ? (
          <a
            href={companyUrl}
            target="_blank"
            rel="noopener noreferrer"
            class={`text-sm font-medium hover:opacity-75 transition-opacity ${type === 'work' ? 'text-accent-cyan' : 'text-accent-purple'}`}
          >
            {company}
          </a>
        ) : (
          <span class={`text-sm font-medium ${type === 'work' ? 'text-accent-cyan' : 'text-accent-purple'}`}>
            {company}
          </span>
        )}
      </div>
      <span class="text-slate-400 text-xs font-mono bg-elevated px-2.5 py-1 rounded shrink-0">
        {startDate} – {endDate}
      </span>
    </div>

    <ul class="space-y-1.5 mb-4">
      {description.map(item => (
        <li class="text-slate-400 text-sm flex gap-2.5 leading-relaxed">
          <span class={`shrink-0 mt-0.5 ${type === 'work' ? 'text-accent-cyan' : 'text-accent-purple'}`}>▹</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>

    <div class="flex flex-wrap gap-1.5">
      {tags.map(tag => (
        <span class="text-xs px-2 py-0.5 bg-elevated text-slate-300 rounded font-mono border border-elevated/80">
          {tag}
        </span>
      ))}
    </div>
  </div>
</div>
