---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Edison Hsieh — Full Stack Engineer',
  description = 'Personal portfolio of Edison Hsieh, a Full Stack Engineer specializing in web development, AI integration, and open source.',
} = Astro.props
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://wizardhsieh.com" />
    <meta property="og:image" content="https://wizardhsieh.com/images/og.png" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://wizardhsieh.com/images/og.png" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-base text-slate-200 font-sans antialiased">
    <slot />
  </body>
</html>
